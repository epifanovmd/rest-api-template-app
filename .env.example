# ─── Server ──────────────────────────────────────────────────────────────────
PUBLIC_HOST=127.0.0.1
SERVER_PORT=8181
SERVER_HOST=0.0.0.0

# ─── Rate limit ───────────────────────────────────────────────────────────────
RATE_LIMIT=
RATE_LIMIT_INTERVAL=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_IPS=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-min-16-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars

# ─── OTP / Reset password ─────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=5
RESET_PASS_TOKEN_EXPIRE_MINUTES=60
WEB_URL_RESET_PASSWORD=http://localhost:3000/reset-password?token={{token}}

# ─── WebAuthn / Passkeys ──────────────────────────────────────────────────────
WEB_AUTHN_RP_NAME=Test
WEB_AUTHN_RP_HOST=localhost
WEB_AUTHN_RP_SCHEMA=http
WEB_AUTHN_RP_PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=pg_user
POSTGRES_PASSWORD=pg_password
POSTGRES_DATA=/data/postgres

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_USER=
SMTP_PASS=
