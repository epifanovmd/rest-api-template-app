{
  "name": "rest-api",
  "version": "1.0.1",
  "description": "REST API Template App",
  "private": true,
  "license": "MIT",
  "engines": {
    "npm": ">=8.5.0",
    "yarn": ">=1.22.18",
    "node": ">=16.14.2"
  },
  "homepage": "https://epifanovmd.github.io/rest-api-template-app",
  "author": {
    "name": "Epifanov Andrei",
    "email": "epifanovmd@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/epifanovmd/rest-api-template-app.git"
  },
  "scripts": {
    "dev": "yarn generate && nodemon",
    "dev:types": "tsc --noEmit --watch --preserveWatchOutput",
    "dev:routes": "nodemon --watch \"src/modules\" --ext ts --exec \"yarn generate\" --ignore \"src/routes.ts\" --delay 1",
    "build": "yarn generate && rollup -c",
    "server": "NODE_ENV=production node build/main.js",
    "generate": "tsoa routes && tsoa swagger",
    "test": "mocha",
    "lint": "eslint \"src/**\"",
    "lint:fix": "eslint --fix \"src/**\"",
    "prettier:fix": "prettier --parser typescript --write src/**/*.ts",
    "outdated": "yarn outdated",
    "postinstall": "patch-package",
    "migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d src/core/db/data-source.ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d src/core/db/data-source.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d src/core/db/data-source.ts"
  },
  "dependencies": {
    "@force-dev/utils": "^1.3.5",
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^3.0.2",
    "@koa/router": "^13.0.0",
    "@simplewebauthn/server": "^13.0.0",
    "@simplewebauthn/types": "^12.0.0",
    "bcrypt": "^6.0.0",
    "blurhash": "^2.0.5",
    "cheerio": "^1.2.0",
    "class-validator": "^0.14.3",
    "cookie": "^0.5.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "firebase-admin": "^13.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "helmet": "^5.0.2",
    "inversify": "^6.0.2",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.13.4",
    "koa-bodyparser": "^4.3.0",
    "koa-helmet": "^6.1.0",
    "koa-mount": "^4.2.0",
    "koa-ratelimit": "^5.1.0",
    "koa-static": "^5.0.0",
    "koa2-router": "^2.0.1",
    "koa2-swagger-ui": "^5.5.0",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "sha256": "^0.2.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.4.1",
    "tslib": "^2.8.1",
    "tsoa": "^4.1.3",
    "typeorm": "^0.3.28",
    "uuid": "^8.3.2",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/bcrypt": "^6.0.0",
    "@types/bluebird": "^3.5.36",
    "@types/chai": "^5.2.3",
    "@types/cookie": "^0.5.0",
    "@types/cookie-parser": "^1.4.2",
    "@types/ejs": "^3.1.5",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^8.5.8",
    "@types/koa": "^2.13.4",
    "@types/koa-bodyparser": "^4.3.7",
    "@types/koa-helmet": "^6.0.4",
    "@types/koa-logger": "^3.1.5",
    "@types/koa-mount": "^4.0.5",
    "@types/koa-ratelimit": "^5.0.5",
    "@types/koa-static": "^4.0.4",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^17.0.24",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "@types/sha256": "^0.2.0",
    "@types/sharp": "^0.32.0",
    "@types/sinon": "^21.0.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.19.0",
    "@typescript-eslint/parser": "^5.19.0",
    "chai": "^6.2.2",
    "eslint": "^8.13.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "lint-staged": "^12.3.8",
    "mocha": "^11.7.5",
    "nodemon": "^2.0.15",
    "patch-package": "^8.0.1",
    "plop": "^4.0.1",
    "prettier": "^2.6.2",
    "rollup": "^4.18.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "sinon": "^21.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts}": [
      "prettier --parser typescript --write src/**/*.{json,ts}",
      "eslint --fix \"src/**\"",
      "git add"
    ]
  }
}
